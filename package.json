{
  "name": "kanban-app",
  "private": true,
  "version": "1.0.0",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "rm -rf release dist && xattr -cr . && vite build && electron-builder --mac",
    "electron:build:dir": "rm -rf release dist && xattr -cr . && vite build && electron-builder --mac --dir",
    "electron:build:win": "rm -rf release dist && vite build && electron-builder --win",
    "electron:build:all": "rm -rf release dist && xattr -cr . && vite build && electron-builder --mac --win"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "electron": "^35.1.2",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.1",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.kanban.app",
    "productName": "Kanban",
    "mac": {
      "target": ["dmg", "dir"],
      "category": "public.app-category.productivity",
      "identity": null
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "electron/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Kanban"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "buildResources": "electron",
      "output": "release"
    }
  }
}
